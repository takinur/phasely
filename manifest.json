{
    "manifest_version": 3,
    "name": "Phasely",
    "version": "1.0.2",
    "description": "Auto-fill job applications from your profile in one click.",
    "permissions": ["activeTab", "scripting", "storage", "identity"],
    "action": {
        "default_popup": "src/popup.html",
        "default_title": "Phasely",
        "default_icon": {
            "16": "src/assets/phasely-icon.svg",
            "48": "src/assets/phasely-icon.svg",
            "128": "src/assets/phasely-icon.svg"
        }
    },
    "background": {
        "service_worker": "src/background.ts"
    },
    "content_scripts": [
        {
            "matches": ["https://*/*"],
            "js": ["src/content.ts"],
            "run_at": "document_idle"
        }
    ],
    "options_ui": {
        "page": "src/options.html",
        "open_in_tab": true
    },
    "icons": {
        "16": "src/assets/phasely-icon.svg",
        "48": "src/assets/phasely-icon.svg",
        "128": "src/assets/phasely-icon.svg"
    }
}
